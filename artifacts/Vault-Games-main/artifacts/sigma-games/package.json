{
  "name": "@workspace/sigma-games",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others \"vite --config vite.config.ts --host 0.0.0.0\" \"tsx watch server/index.ts\"",
