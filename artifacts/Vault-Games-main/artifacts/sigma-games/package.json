    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "resend": "^4.0.0",
    "multer": "^1.4.5-lts.2",
    "pg": "^8.13.3",
    "react-chessboard": "^4.7.2",
    "sudoku-gen": "^1.0.2",
    "tsx": "^4.19.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "catalog:",
    "@types/pg": "^8.11.11",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "clsx": "catalog:",
    "lucide-react": "catalog:",
